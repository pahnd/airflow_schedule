        <mxCell id="czMzne_ZfhmWIMXkXQRc-48" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="rm -rf /tmp/nuri-airflow&lt;div&gt;mkdir -p /tmp/nuri-airflow&lt;/div&gt;&lt;div&gt;git clone osscp/nuri-airflow /tmp/nuri-airflow&lt;/div&gt;&lt;div&gt;git -C /tmp/nuri-airflow checkout development&lt;/div&gt;&lt;div&gt;cp build/create_airflow_config.py .&lt;/div&gt;&lt;div&gt;python3 create_airflow_config.py /tmp/nuri-airflow&lt;/div&gt;&lt;div&gt;rm -rf /tmp/nuri-airflow/schemas&lt;/div&gt;&lt;div&gt;mkdir -p /tmp/nuri-airflow/schemas&lt;/div&gt;&lt;div&gt;cp -r config/* /tmp/nuri-airflow/schemas&lt;/div&gt;&lt;div&gt;git -C /tmp/nuri-airflow add .&lt;/div&gt;&lt;div&gt;git -C /tmp/nuri-airflow commit -am &quot;nuri-airflow update by nuri-embulk&quot; || true&lt;/div&gt;&lt;div&gt;git -C /tmp/nuri-airflow push || true&lt;/div&gt;&lt;div&gt;rm -rf create_airflow_config.py&lt;/div&gt;&lt;div&gt;rm -rf /tmp/nuri-airflow&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="440" x="-455" y="1596.25" as="geometry" />
        </mxCell>
        <mxCell id="czMzne_ZfhmWIMXkXQRc-50" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Copy file config của nuri-embulk sang repository của nuri-airflow:&lt;div&gt;&lt;span style=&quot;&quot;&gt;cp -r nuri-embulk/config nuri-airflow/schemas&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;python3 create_airflow_config.py /tmp/nuri-airflow&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Đọc các đường dẫn trong thư mục /tmp/nuri-embulk/config từ đó sắp xếp thành thứ tự, sau đó tạo ra file nuri-airflow/configs/base.yaml&lt;br&gt;&lt;br&gt;ví dụ tasks:&lt;br&gt;1 - dbms: mariadb-ext-regional - db: A1&lt;/div&gt;&lt;div&gt;1 - dbms: mariadb-global - db: A2&lt;/div&gt;&lt;div&gt;1 - dbms: mariadb-regional - db: A3&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;=&amp;gt; 3 task này sẽ được thực hiện cùng lúc&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Sau đó đến task:&lt;/div&gt;&lt;div&gt;2 - dbms: mariadb-ext-regional -db: B1&lt;/div&gt;&lt;div&gt;2 - dbms: mariadb-global: -db: B2&lt;/div&gt;&lt;div&gt;2 - dbms: mariadb-ext-regional - db: B3&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;-&amp;gt; Mục đích để đảm bảo các dbms cùng nhau thực hiện không phải là tasks 1 lại 3 db cùng là mariadb-ext-regional chạy&lt;/div&gt;" vertex="1">
          <mxGeometry height="372.5" width="280" x="-950" y="1540" as="geometry" />
        </mxCell>
        <mxCell id="czMzne_ZfhmWIMXkXQRc-52" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="set_last_commiter" vertex="1">
          <mxGeometry height="60" width="120" x="460" y="765" as="geometry" />
        </mxCell>
        <mxCell id="czMzne_ZfhmWIMXkXQRc-54" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;font color=&quot;#1f2328&quot; style=&quot;font-size: 16px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Dockerfile:&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul style=&quot;box-sizing: border-box; margin-top: 0px; margin-bottom: 16px; padding-left: 2em; color: rgb(31, 35, 40); background-color: rgb(255, 255, 255);&quot;&gt;&lt;li style=&quot;box-sizing: border-box;&quot;&gt;&lt;font&gt;Stage 1: dùng Poetry export để tạo requirements.txt.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Stage 2: Sử dụng embulk-base tạo môi trường Embulk + JRuby, cấu hình gem source, cài Embulk plugins (MySQL input/output).&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font style=&quot;&quot;&gt;Sau đó (vẫn stage 2): cài Python dependencies và chạy một FastAPI app bằng Uvicorn.&lt;/font&gt;&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="115" width="790" x="980" y="355" as="geometry" />
        </mxCell>
        <mxCell id="czMzne_ZfhmWIMXkXQRc-55" parent="1" style="whiteSpace=wrap;html=1;align=left;" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Dockerfile_embulk_base&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Stage 1: Download package embulk từ minio&lt;/li&gt;&lt;li&gt;Stage 2: Sử dụng để&amp;nbsp;&amp;nbsp;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;Cài đặt openjdk-11-jdk, python3.11, pip, netcat&lt;/li&gt;&lt;li&gt;Copy từ stage 1 embulk.jar và jruby-complete&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;div&gt;-&amp;gt; Image Ubuntu with 2 files /usr/local/bin/embulk.jar and&amp;nbsp; /jruby-complete-9.4.3.0.jar&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="470" x="980" y="490" as="geometry" />
        </mxCell>
        <mxCell id="_nvuyuZxYllZ9lhAfhZw-1" parent="1" style="whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;span style=&quot;color: rgb(31, 35, 40); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font&gt;&lt;b&gt;src/nuri_dw.py&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(31, 35, 40); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;font&gt;&lt;span style=&quot;color: rgb(31, 35, 40); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; background-color: rgb(255, 255, 255);&quot;&gt;Function&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em; color: rgb(31, 35, 40);&quot;&gt;job_result_set(...)&lt;/code&gt;&lt;span style=&quot;color: rgb(31, 35, 40); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;có mục đích ghi (upsert) kết quả job (“Success/Fail”) vào bảng DW&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em; color: rgb(31, 35, 40);&quot;&gt;dw.job_pass_or_fail&lt;/code&gt;&lt;span style=&quot;color: rgb(31, 35, 40); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;trên MySQL&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="630" x="980" y="685" as="geometry" />
        </mxCell>
        <mxCell id="_nvuyuZxYllZ9lhAfhZw-2" parent="1" style="whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;font color=&quot;#1f2328&quot; face=&quot;Mona Sans VF, -apple-system, BlinkMacSystemFont, Segoe UI, Noto Sans, Helvetica, Arial, sans-serif, Apple Color Emoji, Segoe UI Emoji&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#1f2328&quot; face=&quot;Mona Sans VF, -apple-system, BlinkMacSystemFont, Segoe UI, Noto Sans, Helvetica, Arial, sans-serif, Apple Color Emoji, Segoe UI Emoji&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#1f2328&quot; face=&quot;Mona Sans VF, -apple-system, BlinkMacSystemFont, Segoe UI, Noto Sans, Helvetica, Arial, sans-serif, Apple Color Emoji, Segoe UI Emoji&quot;&gt;&lt;b&gt;Embulk fastapi&amp;nbsp;&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#1f2328&quot; face=&quot;Mona Sans VF, -apple-system, BlinkMacSystemFont, Segoe UI, Noto Sans, Helvetica, Arial, sans-serif, Apple Color Emoji, Segoe UI Emoji&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;ol style=&quot;box-sizing: border-box; margin-top: 0px; margin-bottom: 16px; padding-left: 2em; background-color: rgb(255, 255, 255); color: rgb(31, 35, 40);&quot;&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box;&quot;&gt;&lt;font&gt;Đọc JSON body → lấy&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;dbms/db/name&lt;/code&gt;&amp;nbsp;(+&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;task_id/run_id&lt;/code&gt;).&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Gắn&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;TaskIDFilter&lt;/code&gt;&amp;nbsp;vào&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;logger&lt;/code&gt;&amp;nbsp;theo request.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Lấy template Embulk từ&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;yaml_data_dict[f&quot;{dbms}/{db}/{name}&quot;]&lt;/code&gt;.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;;&quot;&gt;Chỉnh config:&lt;/font&gt;&lt;ul style=&quot;box-sizing: border-box; margin-top: 0px; margin-bottom: 0px; padding-left: 2em;&quot;&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box;&quot;&gt;&lt;font&gt;nếu&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;out.mode == incremental&lt;/code&gt;&amp;nbsp;→ đổi sang&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;insert&lt;/code&gt;, và&amp;nbsp;&lt;span style=&quot;box-sizing: border-box; font-weight: 600;&quot;&gt;không xoá dữ liệu trước&lt;/span&gt;&amp;nbsp;(&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;is_delete=False&lt;/code&gt;).&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;nếu&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;dbms == mariadb-global&lt;/code&gt;&amp;nbsp;→ chỉ lấy 1 filter đầu tiên.&lt;/font&gt;&lt;/li&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;font color=&quot;#1f2328&quot; face=&quot;Mona Sans VF, -apple-system, BlinkMacSystemFont, Segoe UI, Noto Sans, Helvetica, Arial, sans-serif, Apple Color Emoji, Segoe UI Emoji&quot;&gt;{ &quot;type&quot;: &quot;column&quot;, &quot;add_columns&quot;: [ {&quot;name&quot;: &quot;offering_cd&quot;, &quot;type&quot;: &quot;string&quot;, &quot;default&quot;: os.environ.get(&quot;OFFERING&quot;)} ], }&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Dump YAML ra file config trong&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;TMP_CONFIG_DIR&lt;/code&gt;.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Acquire lock theo&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;(dbms, db, table)&lt;/code&gt;&amp;nbsp;để tránh chạy đồng thời cùng target.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Check source table exist; nếu bảng không tồn tại thì “Skipped” (ghi DW tables) và return.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Nếu&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;is_delete&lt;/code&gt;&amp;nbsp;→ gọi&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;delete_table_data&lt;/code&gt;. (Nếu không phải mode incremental)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Chạy&amp;nbsp;&lt;code style=&quot;box-sizing: border-box; font-family: &amp;quot;Monaspace Neon&amp;quot;, ui-monospace, SFMono-Regular, &amp;quot;SF Mono&amp;quot;, Menlo, Consolas, &amp;quot;Liberation Mono&amp;quot;, monospace; tab-size: 4; white-space: break-spaces; background-color: rgba(129, 139, 152, 0.12); border-radius: 6px; margin: 0px; padding: 0.2em 0.4em;&quot;&gt;embulk run &amp;lt;config&amp;gt;&lt;/code&gt;&amp;nbsp;bằng subprocess async, stream stdout/stderr.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Nếu success → ghi DW table “Success”; nếu fail → mail_send + trả 500.&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: light-dark(rgb(31, 35, 40), rgb(205, 208, 212)); font-family: &amp;quot;Mona Sans VF&amp;quot;, -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; box-sizing: border-box; margin-top: 0.25em;&quot;&gt;&lt;font&gt;Release lock + remove filter + trả response.&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
